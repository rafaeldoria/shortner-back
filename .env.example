NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/shortner?appName=shortner
BASE_URL=http://localhost:3100
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://shortner.it-rod.com,https://urlshortner.it-rod.com
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRES_IN=1d
AUTH_COOKIE_NAME=shortner_session
EMAIL_VERIFICATION_EXPIRES_IN=1d
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=Shortner <onboarding@your-domain.example>
ALERT_SEND_EMAIL=alerts@your-domain.example
